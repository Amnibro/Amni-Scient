<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Amni-Explore: Galactic Cartographics</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--cm:#00b4ff;--ca:#ff8800;--cd:#4a6a8a;--cp:rgba(3,8,20,0.9);--cb:rgba(0,120,200,0.45);--ct:#c8dcf0}
body{overflow:hidden;background:#010208;font-family:'Segoe UI',sans-serif;color:var(--ct);cursor:default}
canvas{display:block;position:fixed;top:0;left:0;z-index:0}
.pnl{background:var(--cp);border:1px solid var(--cb);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px)}
.hud{position:fixed;z-index:10;pointer-events:none}
.hud>*{pointer-events:auto}
#g-hud{top:16px;left:16px}
#g-info{padding:12px 16px;width:280px}
#g-info h2{font-size:11px;font-weight:400;letter-spacing:3px;color:var(--cm);text-transform:uppercase;margin-bottom:3px}
#g-info .scr{font-size:16px;font-weight:600}
#g-info .zm{font-size:10px;color:var(--cd);margin-top:6px;letter-spacing:1px}
#g-sel{position:fixed;right:16px;top:16px;width:300px;padding:16px;z-index:10;display:none}
#g-sel h3{font-size:12px;font-weight:400;letter-spacing:2px;color:var(--cm);text-transform:uppercase;margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--cb)}
#g-sel .bd{font-size:11px;color:var(--cd);white-space:pre-line;line-height:1.6}
#g-sel .enter-btn{display:block;width:100%;margin-top:12px;padding:8px;background:rgba(0,80,160,0.35);border:1px solid var(--cb);color:var(--ct);font-size:11px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;text-align:center}
#g-sel .enter-btn:hover{background:rgba(0,120,200,0.5);border-color:var(--cm);box-shadow:0 0 16px rgba(0,160,255,0.2)}
#g-hint{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);z-index:10;font-size:10px;letter-spacing:2px;color:var(--cd);text-transform:uppercase;pointer-events:none;opacity:0.7}
canvas{cursor:grab}
canvas:active{cursor:grabbing}
#s-hud{position:fixed;top:0;left:0;width:100%;height:100%;z-index:10;display:none;pointer-events:none}
#s-hud>*{pointer-events:auto}
#s-top{position:absolute;top:16px;left:50%;transform:translateX(-50%);text-align:center}
#s-top h1{font-size:18px;font-weight:300;letter-spacing:6px;color:var(--cm);text-shadow:0 0 20px rgba(0,180,255,0.3)}
#s-top p{font-size:10px;color:var(--cd);letter-spacing:2px;margin-top:2px}
#s-back{position:absolute;top:16px;left:16px;background:none;border:1px solid var(--cb);color:var(--cd);padding:6px 16px;font-size:10px;letter-spacing:2px;cursor:pointer;text-transform:uppercase;transition:all 0.2s}
#s-back:hover{color:var(--cm);border-color:var(--cm);box-shadow:0 0 10px rgba(0,160,255,0.15)}
#s-planets{position:absolute;left:16px;top:60px;width:260px;max-height:calc(100vh - 100px);overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--cb) transparent}
#s-planets::-webkit-scrollbar{width:3px}
#s-planets::-webkit-scrollbar-thumb{background:var(--cb);border-radius:2px}
.p-entry{display:flex;align-items:center;gap:10px;padding:10px 14px;cursor:pointer;border-bottom:1px solid rgba(0,60,120,0.15);transition:background 0.2s;border-left:2px solid transparent}
.p-entry:hover{background:rgba(0,80,160,0.2)}
.p-entry.active{background:rgba(0,100,200,0.25);border-left-color:var(--cm)}
.p-dot{width:14px;height:14px;border-radius:50%;flex-shrink:0}
.p-entry .p-nm{font-size:11px;color:var(--ct);text-transform:uppercase;letter-spacing:1px}
.p-entry .p-tp{font-size:9px;color:var(--cd);margin-top:1px}
#s-pinfo{position:absolute;right:16px;bottom:16px;width:280px;padding:14px;display:none}
#s-pinfo h4{font-size:11px;letter-spacing:2px;color:var(--cm);text-transform:uppercase;margin-bottom:6px;padding-bottom:4px;border-bottom:1px solid var(--cb)}
#s-pinfo .bd{font-size:10px;color:var(--cd);white-space:pre-line;line-height:1.6}
#s-score{position:absolute;top:16px;right:16px;padding:8px 14px;font-size:12px}
#s-score span{color:var(--cm);font-weight:600}
#xhair{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:11;pointer-events:none;width:36px;height:36px;display:none}
#xhair svg{width:100%;height:100%;filter:drop-shadow(0 0 3px var(--cm))}
#msg{position:fixed;top:20%;left:50%;transform:translateX(-50%);z-index:12;font-size:16px;letter-spacing:3px;color:var(--cm);text-transform:uppercase;text-shadow:0 0 16px var(--cm);opacity:0;transition:opacity 0.3s;pointer-events:none}
#msg.show{opacity:1}
#fade{position:fixed;top:0;left:0;width:100%;height:100%;background:#010208;z-index:30;opacity:0;pointer-events:none;transition:opacity 0.4s}
#fade.on{opacity:1;pointer-events:all}
#loading{position:fixed;top:0;left:0;width:100%;height:100%;z-index:50;background:#010208;display:flex;align-items:center;justify-content:center;flex-direction:column}
#loading h1{font-size:14px;font-weight:300;letter-spacing:6px;color:var(--cm);margin-bottom:10px}
#loading .bar{width:180px;height:2px;background:rgba(0,60,120,0.3);border-radius:1px;overflow:hidden}
#loading .fill{height:100%;width:0%;background:var(--cm);transition:width 0.3s;box-shadow:0 0 6px var(--cm)}
#pause{position:fixed;top:0;left:0;width:100%;height:100%;z-index:25;display:none;align-items:center;justify-content:center;background:rgba(1,2,8,0.85);backdrop-filter:blur(6px)}
#pause.open{display:flex}
#pause-box{width:320px;padding:28px;text-align:center}
#pause-box h2{font-size:18px;font-weight:300;letter-spacing:5px;color:var(--cm);margin-bottom:4px}
#pause-box .sub{font-size:11px;color:var(--cd);letter-spacing:3px;margin-bottom:20px}
.mbtn{display:block;width:100%;padding:9px;margin:6px 0;background:rgba(0,60,120,0.35);border:1px solid var(--cb);color:var(--ct);font-size:11px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s}
.mbtn:hover{background:rgba(0,100,180,0.45);border-color:var(--cm);box-shadow:0 0 12px rgba(0,160,255,0.15)}
#site-back{position:fixed;bottom:16px;right:16px;z-index:10;padding:8px 16px;background:rgba(3,8,20,0.9);border:1px solid rgba(0,120,200,0.45);color:var(--cd);font-size:10px;letter-spacing:2px;text-decoration:none;text-transform:uppercase;transition:all 0.2s;backdrop-filter:blur(10px)}
#site-back:hover{color:var(--cm);border-color:var(--cm);box-shadow:0 0 10px rgba(0,160,255,0.15)}
</style>
</head>
<body>
<div id="loading"><h1>GALACTIC CARTOGRAPHICS</h1><div class="bar"><div class="fill" id="lbar"></div></div></div>
<div id="g-hud" class="hud">
<div id="g-info" class="pnl">
<h2>Galactic Cartographics</h2>
<div class="scr">DATA SCANS: <span id="g-score">0</span> TB</div>
<div class="zm" id="g-zoom">ZOOM: GALAXY VIEW</div>
</div>
</div>
<div id="g-sel" class="pnl"></div>
<div id="g-hint">Left-drag: rotate &middot; Right-drag: pan &middot; Scroll: zoom &middot; Click star to select</div>
<div id="s-hud">
<button id="s-back" class="pnl">&larr; Galaxy [ESC]</button>
<div id="s-top"><h1 id="s-name"></h1><p id="s-class"></p></div>
<div id="s-planets" class="pnl"></div>
<div id="s-pinfo" class="pnl"><h4>Planet Data</h4><div class="bd" id="s-pbody"></div></div>
<div id="s-score" class="pnl">DATA: <span id="s-scr">0</span> TB</div>
</div>
<div id="xhair"><svg viewBox="0 0 36 36"><circle cx="18" cy="18" r="12" fill="none" stroke="var(--cm)" stroke-width="1" opacity="0.5"/><line x1="18" y1="2" x2="18" y2="9" stroke="var(--cm)" stroke-width="1.2"/><line x1="18" y1="27" x2="18" y2="34" stroke="var(--cm)" stroke-width="1.2"/><line x1="2" y1="18" x2="9" y2="18" stroke="var(--cm)" stroke-width="1.2"/><line x1="27" y1="18" x2="34" y2="18" stroke="var(--cm)" stroke-width="1.2"/><circle cx="18" cy="18" r="1.5" fill="var(--cm)"/></svg></div>
<div id="msg"></div>
<div id="fade"></div>
<div id="pause"><div id="pause-box" class="pnl"><h2>Ship Computer</h2><div class="sub">PAUSED</div><button class="mbtn" id="btn-resume">Resume</button><button class="mbtn" id="btn-fs">Toggle Fullscreen</button></div></div>
<a id="site-back" href="../amni-explore.html">&larr; AMNI-SCIENT</a>
<script type="importmap">{"imports":{"three":"https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js","three/addons/":"https://cdn.jsdelivr.net/npm/three@0.170.0/examples/jsm/"}}</script>
<script type="module">
import*as T from'three';
import{EffectComposer}from'three/addons/postprocessing/EffectComposer.js';
import{RenderPass}from'three/addons/postprocessing/RenderPass.js';
import{UnrealBloomPass}from'three/addons/postprocessing/UnrealBloomPass.js';
import wInit,{gen_galaxy,gen_systems,gen_texture}from'./pkg/amni_explore_wasm.js';
const $=s=>document.querySelector(s),$$=s=>document.querySelectorAll(s);
const V={GAL:0,SYS:1};
const GR=5000,GALP=80000,NPRC=3000;
const API='https://exoplanetarchive.ipac.caltech.edu/TAP/sync?query=select+top+500+pl_name,hostname,pl_rade,pl_bmasse,st_teff,pl_orbsmax,pl_eqt+from+ps+where+st_teff+is+not+null+and+pl_rade+is+not+null&format=json';
let scene,cam,ren,comp,ray,view=V.GAL,score=0,selSys=null,sysObjs=[],allSys=[];
let galPts,sysPts;
let gTh=0,gPh=0.4,gD=9000,gTgt=new T.Vector3(0,0,0);
let orbTh=0,orbPh=Math.PI/5,orbD=600,orbTgt=new T.Vector3();
let drag={on:false,btn:-1,lx:0,ly:0};
let densPlane=null,dirty=true;
const GAL_VS=`attribute vec3 color;varying vec3 vC;void main(){vC=color;vec4 mv=modelViewMatrix*vec4(position,1.0);gl_PointSize=clamp(10.0*(300.0/(-mv.z)),1.0,35.0);gl_Position=projectionMatrix*mv;}`;
const GAL_FS=`varying vec3 vC;void main(){float d=length(gl_PointCoord-vec2(0.5));if(d>0.5)discard;float a=(1.0-smoothstep(0.0,0.5,d))*0.8;gl_FragColor=vec4(vC,a);}`;
const SYS_VS=`attribute vec3 color;varying vec3 vC;uniform float uSz;void main(){vC=color;vec4 mv=modelViewMatrix*vec4(position,1.0);gl_PointSize=clamp(uSz*(300.0/(-mv.z)),2.0,60.0);gl_Position=projectionMatrix*mv;}`;
const SYS_FS=`varying vec3 vC;uniform float uOp;void main(){float d=length(gl_PointCoord-vec2(0.5));if(d>0.5)discard;float a=(1.0-smoothstep(0.1,0.5,d))*uOp;gl_FragColor=vec4(vC,a);}`;
const clamp=(v,mn,mx)=>v<mn?mn:v>mx?mx:v;
const hash=n=>(Math.sin(n*127.1+311.7)*43758.5453)%1;
function wasmTex(type,seed,rade){
const sz=256,raw=gen_texture(type,seed,rade,sz);
const cv=document.createElement('canvas');cv.width=cv.height=sz;
const ctx=cv.getContext('2d'),img=ctx.createImageData(sz,sz);
img.data.set(raw);
ctx.putImageData(img,0,0);
const tex=new T.CanvasTexture(cv);tex.colorSpace=T.SRGBColorSpace;return tex;
}
function buildGalaxy(galData){
const n=galData.length/6;
const pos=new Float32Array(n*3),col=new Float32Array(n*3);
for(let i=0;i<n;i++){
pos[i*3]=galData[i*6];pos[i*3+1]=galData[i*6+1];pos[i*3+2]=galData[i*6+2];
col[i*3]=galData[i*6+3];col[i*3+1]=galData[i*6+4];col[i*3+2]=galData[i*6+5];
}
const geo=new T.BufferGeometry();
geo.setAttribute('position',new T.BufferAttribute(pos,3));
geo.setAttribute('color',new T.BufferAttribute(col,3));
galPts=new T.Points(geo,new T.ShaderMaterial({vertexShader:GAL_VS,fragmentShader:GAL_FS,transparent:true,depthWrite:false}));
scene.add(galPts);
}
function buildSysPts(){
const n=allSys.length;
const pos=new Float32Array(n*3),col=new Float32Array(n*3);
for(let i=0;i<n;i++){
const s=allSys[i];
pos[i*3]=s.pos[0];pos[i*3+1]=s.pos[1];pos[i*3+2]=s.pos[2];
col[i*3]=s.sc[0];col[i*3+1]=s.sc[1];col[i*3+2]=s.sc[2];
}
const geo=new T.BufferGeometry();
geo.setAttribute('position',new T.BufferAttribute(pos,3));
geo.setAttribute('color',new T.BufferAttribute(col,3));
sysPts=new T.Points(geo,new T.ShaderMaterial({vertexShader:SYS_VS,fragmentShader:SYS_FS,transparent:true,depthWrite:false,uniforms:{uSz:{value:20},uOp:{value:0.9}}}));
scene.add(sysPts);
}
function genDensMap(){
setTimeout(()=>{
const sz=512,rt=new T.WebGLRenderTarget(sz,sz,{minFilter:T.LinearFilter,magFilter:T.LinearFilter});
const oCam=new T.OrthographicCamera(-GR*1.3,GR*1.3,GR*1.3,-GR*1.3,-GR*2,GR*2);
oCam.position.set(0,100,0);oCam.lookAt(0,0,0);
const oldMat=galPts.material,oldSysVis=sysPts?.visible,oldFog=scene.fog;
if(sysPts)sysPts.visible=false;
scene.fog=null;
galPts.material=new T.ShaderMaterial({vertexShader:`attribute vec3 color;varying vec3 vC;void main(){vC=color;gl_PointSize=5.0;gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0);}`,fragmentShader:GAL_FS,transparent:true,blending:T.AdditiveBlending,depthWrite:false});
const oldClear=ren.getClearColor(new T.Color()),oldAlpha=ren.getClearAlpha();
ren.setClearColor(0x000000,1);ren.setRenderTarget(rt);ren.render(scene,oCam);ren.setRenderTarget(null);ren.setClearColor(oldClear,oldAlpha);
galPts.material=oldMat;
if(sysPts)sysPts.visible=oldSysVis;
scene.fog=oldFog;
const pg=new T.PlaneGeometry(GR*2.6,GR*2.6);
densPlane=new T.Mesh(pg,new T.MeshBasicMaterial({map:rt.texture,transparent:true,blending:T.AdditiveBlending,depthWrite:false,side:T.DoubleSide,opacity:0}));
densPlane.rotation.x=-Math.PI/2;densPlane.visible=false;
scene.add(densPlane);updateGalCam();dirty=true;
},50);
}
function mkGlow(c,s){
const cv=document.createElement('canvas');cv.width=cv.height=64;
const ctx=cv.getContext('2d'),g=ctx.createRadialGradient(32,32,0,32,32,32);
g.addColorStop(0,`rgba(${c[0]*255|0},${c[1]*255|0},${c[2]*255|0},0.9)`);
g.addColorStop(0.25,`rgba(${c[0]*255|0},${c[1]*255|0},${c[2]*255|0},0.35)`);
g.addColorStop(1,'rgba(0,0,0,0)');
ctx.fillStyle=g;ctx.fillRect(0,0,64,64);
const tex=new T.CanvasTexture(cv);
const sp=new T.Sprite(new T.SpriteMaterial({map:tex,transparent:true,blending:T.AdditiveBlending,depthWrite:false}));
sp.scale.set(s,s,1);return sp;
}
function mkOrbitRing(rad){
const pts=[];for(let i=0;i<=128;i++){const a=(i/128)*Math.PI*2;pts.push(new T.Vector3(Math.cos(a)*rad,0,Math.sin(a)*rad))}
return new T.Line(new T.BufferGeometry().setFromPoints(pts),new T.LineBasicMaterial({color:0x003860,transparent:true,opacity:0.3}));
}
function enterSys(sys){
if(view===V.SYS)return;
selSys=sys;view=V.SYS;
$('#fade').classList.add('on');
setTimeout(()=>{
galPts.visible=false;sysPts.visible=false;if(densPlane)densPlane.visible=false;
$('#g-hud').style.display='none';$('#g-sel').style.display='none';$('#g-hint').style.display='none';
$('#s-hud').style.display='block';$('#xhair').style.display='block';
orbTgt.set(0,0,0);orbTh=0;orbPh=Math.PI/5;orbD=600;
const sRad=15+(sys.temp/800);
const sc=sys.sc;
const star=new T.Mesh(new T.SphereGeometry(sRad,32,32),new T.MeshBasicMaterial({color:new T.Color(...sc)}));
star.userData={name:sys.name,desc:`Class: ${sys.cls} Star\nTemp: ${sys.temp}K`,type:'star'};
scene.add(star);sysObjs.push(star);
const glow=mkGlow(sc,sRad*4);scene.add(glow);sysObjs.push(glow);
const lt=new T.PointLight(new T.Color(...sc),3,sRad*50);scene.add(lt);sysObjs.push(lt);
const amb=new T.AmbientLight(0x111825,2);scene.add(amb);sysObjs.push(amb);
$('#s-name').textContent=sys.name;
$('#s-class').textContent=`Class ${sys.cls} | ${sys.temp}K | ${sys.planets.length} planet${sys.planets.length!==1?'s':''}`;
$('#s-planets').innerHTML='';$('#s-scr').textContent=score;
sys.planets.forEach((p,i)=>{
const oRad=sRad*2.5+(i*(sRad*1.2+10));
const seed=hash(i*131+sys.temp*0.01)*1000;
const tex=wasmTex(p.ptype,seed,p.rade);
const pMesh=new T.Mesh(new T.SphereGeometry(clamp(p.rade*1.5,2,25),24,24),new T.MeshStandardMaterial({map:tex,roughness:0.6,metalness:0.05}));
const pivot=new T.Object3D();
pivot.userData.speed=(3+Math.random()*6)/(i+1)*(Math.random()>0.5?1:-1);
const ang=Math.random()*Math.PI*2;
pMesh.position.set(Math.cos(ang)*oRad,0,Math.sin(ang)*oRad);
pMesh.userData={name:p.name,desc:`Type: ${p.ptype}\nRadius: ${p.rade.toFixed(1)} Earth\nMass: ${p.mass} Earth\nEq Temp: ${p.eqt||'Unknown'}K\nOrbit: ${p.orbit||'N/A'} AU`,type:'planet'};
pivot.add(pMesh);scene.add(pivot);sysObjs.push(pivot,pMesh);
const ring=mkOrbitRing(oRad);scene.add(ring);sysObjs.push(ring);
const pal=p.color;
const d=document.createElement('div');d.className='p-entry';
d.innerHTML=`<div class="p-dot" style="background:rgb(${pal[0].map(c=>(c*255)|0).join(',')})"></div><div><div class="p-nm">${p.name}</div><div class="p-tp">${p.ptype} | ${p.rade.toFixed(1)}R</div></div>`;
d.onclick=()=>{
$$('.p-entry').forEach(e=>e.classList.remove('active'));d.classList.add('active');
orbTgt.copy(pMesh.getWorldPosition(new T.Vector3()));
orbD=clamp(p.rade*8,30,200);
$('#s-pinfo').style.display='block';$('#s-pbody').textContent=pMesh.userData.desc;
};
$('#s-planets').appendChild(d);
});
updateSysCam();
setTimeout(()=>$('#fade').classList.remove('on'),50);
},400);
}
function exitSys(){
if(view===V.GAL)return;
$('#fade').classList.add('on');
setTimeout(()=>{
sysObjs.forEach(o=>{if(o.parent)o.parent.remove(o)});sysObjs=[];
galPts.visible=true;sysPts.visible=true;
$('#g-hud').style.display='';$('#g-hint').style.display='';
$('#s-hud').style.display='none';$('#xhair').style.display='none';$('#s-pinfo').style.display='none';
view=V.GAL;updateGalCam();
setTimeout(()=>$('#fade').classList.remove('on'),50);
},400);
}
function updateGalCam(){
dirty=true;
const x=gD*Math.sin(gPh)*Math.sin(gTh),y=gD*Math.cos(gPh),z=gD*Math.sin(gPh)*Math.cos(gTh);
cam.position.set(gTgt.x+x,gTgt.y+y,gTgt.z+z);cam.lookAt(gTgt);
const zl=gD>7000?'GALAXY':gD>3000?'SECTOR':gD>800?'REGION':'LOCAL';
$('#g-zoom').textContent=`ZOOM: ${zl} VIEW`;
if(sysPts){
const sySz=clamp(20*(2000/gD),4,60);
sysPts.material.uniforms.uSz.value=sySz;
const fade=gD<5000?0.9:clamp(0.9*(1-(gD-5000)/1500),0,0.9);
sysPts.visible=fade>0.01;sysPts.material.uniforms.uOp.value=fade;
}
if(densPlane){
const dOp=gD<3500?0:clamp((gD-3500)/3000*0.75,0,0.75);
densPlane.visible=dOp>0.01;densPlane.material.opacity=dOp;
}
}
function updateSysCam(){
dirty=true;
const x=orbD*Math.sin(orbPh)*Math.sin(orbTh),y=orbD*Math.cos(orbPh),z=orbD*Math.sin(orbPh)*Math.cos(orbTh);
cam.position.set(orbTgt.x+x,orbTgt.y+y,orbTgt.z+z);cam.lookAt(orbTgt);
}
function showMsg(t){const e=$('#msg');e.textContent=t;e.classList.add('show');setTimeout(()=>e.classList.remove('show'),2500)}
function selectGalSys(sys){
selSys=sys;
const el=$('#g-sel');el.style.display='block';
const dist=Math.sqrt(Math.pow(sys.pos[0]-2600,2)+Math.pow(sys.pos[1]-2,2)+Math.pow(sys.pos[2],2)).toFixed(0);
el.innerHTML=`<h3>${sys.name}</h3><div class="bd">Class: ${sys.cls} Star\nTemperature: ${sys.temp}K\nPlanets: ${sys.planets.length}\nSource: ${sys.src==='NASA'?'NASA Exoplanet Archive':'Procedural Calculation'}\nDistance: ${dist} Ly from Sol</div><button class="enter-btn" id="enter-sys">Enter System &rarr;</button>`;
$('#enter-sys').onclick=()=>enterSys(sys);
}
async function fetchNASA(){
try{const r=await fetch(API);return r.ok?await r.json():[]}catch{return[]}
}
async function init(){
$('#lbar').style.width='15%';
await wInit();
$('#lbar').style.width='25%';
scene=new T.Scene();
scene.fog=new T.FogExp2(0x010208,0.00004);
cam=new T.PerspectiveCamera(60,innerWidth/innerHeight,1,40000);
ren=new T.WebGLRenderer({antialias:true,powerPreference:'high-performance'});
ren.setSize(innerWidth,innerHeight);
ren.setPixelRatio(Math.min(devicePixelRatio,2));
ren.toneMapping=T.ACESFilmicToneMapping;ren.toneMappingExposure=1.1;
document.body.prepend(ren.domElement);
comp=new EffectComposer(ren);
comp.addPass(new RenderPass(scene,cam));
comp.addPass(new UnrealBloomPass(new T.Vector2(innerWidth*0.5,innerHeight*0.5),0.5,0.3,0.88));
ray=new T.Raycaster();ray.params.Points.threshold=30;
$('#lbar').style.width='40%';
const galData=gen_galaxy(GALP,42);
buildGalaxy(galData);
$('#lbar').style.width='55%';
const nasaRaw=await fetchNASA();
const nasaJson=JSON.stringify(nasaRaw.length?nasaRaw:[]);
$('#lbar').style.width='70%';
const sysJson=gen_systems(nasaJson,NPRC,42);
allSys=JSON.parse(sysJson);
$('#lbar').style.width='85%';
buildSysPts();genDensMap();
$('#lbar').style.width='90%';
updateGalCam();
const cv=ren.domElement;
cv.addEventListener('wheel',e=>{
e.preventDefault();
view===V.GAL?(gD=clamp(gD+e.deltaY*gD*0.001,100,14000),updateGalCam()):(orbD=clamp(orbD+e.deltaY*0.5,20,3000),updateSysCam());
},{passive:false});
cv.addEventListener('mousedown',e=>{drag.on=true;drag.btn=e.button;drag.lx=e.clientX;drag.ly=e.clientY});
cv.addEventListener('contextmenu',e=>e.preventDefault());
window.addEventListener('mouseup',()=>{drag.on=false});
window.addEventListener('mousemove',e=>{
if(!drag.on)return;
const dx=e.clientX-drag.lx,dy=e.clientY-drag.ly;
drag.lx=e.clientX;drag.ly=e.clientY;
if(view===V.GAL&&drag.btn===0){gTh-=dx*0.003;gPh=clamp(gPh-dy*0.003,0.05,Math.PI*0.48);updateGalCam()}
else if(view===V.GAL&&drag.btn===2){
const f=gD*0.0006,ca=Math.cos(gTh),sa=Math.sin(gTh);
gTgt.x-=(dx*ca-dy*sa*Math.cos(gPh))*f;gTgt.z-=(dx*sa+dy*ca*Math.cos(gPh))*f;
gTgt.x=clamp(gTgt.x,-GR*1.2,GR*1.2);gTgt.z=clamp(gTgt.z,-GR*1.2,GR*1.2);updateGalCam();
}
else if(view===V.SYS&&drag.btn===0){orbTh-=dx*0.005;orbPh=clamp(orbPh-dy*0.005,0.1,Math.PI-0.1);updateSysCam()}
});
cv.addEventListener('click',e=>{
if(view===V.GAL){
const mx=(e.clientX/innerWidth)*2-1,my=-(e.clientY/innerHeight)*2+1;
ray.setFromCamera(new T.Vector2(mx,my),cam);
ray.params.Points.threshold=clamp(gD*0.015,5,100);
const hits=ray.intersectObject(sysPts);
if(hits.length){const idx=hits[0].index;if(idx<allSys.length)selectGalSys(allSys[idx])}
}
});
cv.addEventListener('dblclick',e=>{
if(view===V.GAL&&selSys){enterSys(selSys);return}
if(view===V.SYS){
const mx=(e.clientX/innerWidth)*2-1,my=-(e.clientY/innerHeight)*2+1;
ray.setFromCamera(new T.Vector2(mx,my),cam);
const meshes=sysObjs.filter(o=>o.isMesh);
const hits=ray.intersectObjects(meshes,false);
if(hits.length&&hits[0].object.userData.name){
const obj=hits[0].object;
showMsg(`ANALYZING ${obj.userData.name}...`);
score+=10;$('#s-scr').textContent=score;$('#g-score').textContent=score;
const m=obj.material;if(m&&m.color){const oc=m.color.clone();m.color.set(0x00b4ff);setTimeout(()=>m.color.copy(oc),200)}
}
}
});
document.addEventListener('keydown',e=>{
if(e.code==='Escape'){view===V.SYS?exitSys():$('#pause').classList.toggle('open')}
if(e.code==='KeyM'&&view===V.SYS)exitSys();
if(e.code==='F5'){e.preventDefault();localStorage.setItem('amni_save',JSON.stringify({score}));showMsg('DATA SYNCED')}
if(e.code==='F9'){e.preventDefault();const sv=localStorage.getItem('amni_save');if(sv){score=JSON.parse(sv).score;$('#g-score').textContent=score;$('#s-scr').textContent=score;showMsg('DATA LOADED')}}
});
$('#s-back').onclick=exitSys;
$('#btn-resume').onclick=()=>$('#pause').classList.remove('open');
$('#btn-fs').onclick=()=>{document.fullscreenElement?document.exitFullscreen?.():document.documentElement.requestFullscreen?.()};
window.addEventListener('resize',()=>{
cam.aspect=innerWidth/innerHeight;cam.updateProjectionMatrix();
ren.setSize(innerWidth,innerHeight);comp.setSize(innerWidth,innerHeight);dirty=true;
});
$('#lbar').style.width='100%';
setTimeout(()=>{$('#loading').style.display='none';showMsg('GALACTIC CARTOGRAPHICS ONLINE')},300);
animate();
}
function animate(){
requestAnimationFrame(animate);
if(view===V.SYS){sysObjs.forEach(o=>{if(o.isObject3D&&o.userData.speed)o.rotation.y+=o.userData.speed*0.002});dirty=true;}
if(dirty){comp.render();dirty=false;}
}
init();
</script>
</body>
</html>